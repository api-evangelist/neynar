{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neynar.com/schemas/ReactionReqBody",
  "title": "ReactionReqBody",
  "description": "Neynar Farcaster API schema for ReactionReqBody",
  "properties": {
    "idem": {
      "$ref": "#/components/schemas/Idem"
    },
    "reaction_type": {
      "$ref": "#/components/schemas/ReactionType"
    },
    "signer_uuid": {
      "$ref": "#/components/schemas/SignerUUID"
    },
    "target": {
      "description": "Target cast hash (hex string starting with 0x) OR a valid URL.",
      "example": "0x3702ec1b298bb7ac6f00346432d959ad7b05b9a8 -OR- http://neynar.com/",
      "type": "string"
    },
    "target_author_fid": {
      "$ref": "#/components/schemas/Fid"
    }
  },
  "required": [
    "signer_uuid",
    "reaction_type",
    "target"
  ],
  "type": "object"
}