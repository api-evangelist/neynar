{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neynar.com/schemas/DeveloperManagedSigner",
  "title": "DeveloperManagedSigner",
  "description": "Neynar Farcaster API schema for DeveloperManagedSigner",
  "properties": {
    "fid": {
      "$ref": "#/components/schemas/Fid"
    },
    "public_key": {
      "$ref": "#/components/schemas/Ed25519PublicKey"
    },
    "signer_approval_url": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending_approval",
        "approved",
        "revoked"
      ],
      "type": "string"
    }
  },
  "required": [
    "public_key",
    "status"
  ],
  "type": "object"
}