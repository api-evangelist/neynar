{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neynar.com/schemas/ChannelMember",
  "title": "ChannelMember",
  "description": "Neynar Farcaster API schema for ChannelMember",
  "properties": {
