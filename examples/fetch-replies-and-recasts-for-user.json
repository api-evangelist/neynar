{
  "operationId": "fetch-replies-and-recasts-for-user",
  "method": "GET",
  "path": "/v2/farcaster/feed/user/replies_and_recasts/",
  "summary": "Replies and recasts",
  "description": "Fetch recent replies and recasts for a given user FID; sorted by most recent first",
  "tags": [
    "Feed"
  ],
  "parameters": [
    {
      "name": "fid",
      "in": "query",
      "required": true,
      "description": "FID of user whose replies and recasts you want to fetch",
      "schema": {
        "minimum": 1,
        "type": "integer"
      }
    },
    {
      "name": "filter",
      "in": "query",
      "required": false,
      "description": "Filter to fetch only replies or recasts",
      "schema": {
        "default": "all",
        "enum": [
          "replies",
          "recasts",
          "all"
        ],
        "example": "replies",
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of results to fetch",
      "schema": {
        "default": 25,
        "example": 30,
        "format": "int32",
        "maximum": 50,
        "minimum": 1,
        "type": "integer"
      }
    },
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Pagination cursor.",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "viewer_fid",
      "in": "query",
      "required": false,
      "description": "Providing this will return a feed that respects this user's mutes and blocks and includes `viewer_context`.",
      "schema": {
        "minimum": 1,
        "type": "integer"
      }
    }
  ],
  "requestBody": null,
  "responses": {
    "200": {
      "description": "Success",
      "schema": {
        "$ref": "#/components/schemas/FeedResponse"
      },
      "example": null
    },
    "400": {
      "description": "Bad Request",
      "schema": {
        "$ref": "#/components/schemas/ErrorRes"
      },
      "example": null
    }
  }
}