{
  "operationId": "hub-fetch-verifications-by-fid",
  "method": "GET",
  "path": "/v1/verificationsByFid",
  "summary": "Provided by an FID",
  "description": "Fetch verifications provided by a user.",
  "tags": [
    "Verifications"
  ],
  "parameters": [
    {
      "name": "fid",
      "in": "query",
      "required": true,
      "description": "The FID being requested",
      "schema": {
        "type": "integer"
      }
    },
    {
      "name": "address",
      "in": "query",
      "required": false,
      "description": "The optional ETH address to filter by",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "",
      "in": "",
      "required": false,
      "description": ""
    },
    {
      "name": "",
      "in": "",
      "required": false,
      "description": ""
    },
    {
      "name": "",
      "in": "",
      "required": false,
      "description": ""
    }
  ],
  "requestBody": null,
  "responses": {
    "200": {
      "description": "The requested Verifications.",
      "schema": {
        "required": [
          "messages",
          "nextPageToken"
        ],
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Verification"
            }
          },
          "nextPageToken": {
            "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
            "type": "string",
            "format": "byte"
          }
        }
      },
      "example": null
    }
  }
}