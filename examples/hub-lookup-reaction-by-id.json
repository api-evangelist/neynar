        "$ref": "#/components/schemas/ReactionType"
      }
    }
  ],
  "requestBody": null,
  "responses": {
    "200": {
      "description": "The requested Reaction.",
      "schema": {
        "$ref": "#/components/schemas/Reaction"
      },
      "example": null
    }
